UPLOAD_DIR=../uploads

DB_DSN=postgres://USER:PASSWORD@HOST:PORT/DB_NAME?sslmode=disable&TimeZone=UTC
DB_USER=USER-change
DB_PASSWORD=PASSWORD-change
DB_HOST=HOST
DB_PORT=5432
DB_NAME=DB_NAME-change
MAX_CONNS=20
MIN_CONNS=5
MAX_CONN_LIFETIME=30
MAX_CONN_IDLE_TIME=5

BCRYPT_COST=12

LOG_LEVEL=info

JWT_ACCESS_SECRET=change-me-32-chars
JWT_ACCESS_TTL=15
JWT_REFRESH_SECRET=change-me-32-chars
JWT_REFRESH_TTL=10080
JWT_COOKIE_DOMAIN=.example.com
JWT_COOKIE_SECURE=true
JWT_ISSUER=example

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=change
REDIS_DB=0
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE_CONNS=10
REDIS_DIAL_TIMEOUT=5
REDIS_READ_TIMEOUT=3
REDIS_WRITE_TIMEOUT=3
